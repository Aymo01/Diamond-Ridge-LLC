# EmailJS configuration for Vite
# Copy this file to .env and replace values with your EmailJS IDs

VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_QUOTE=your_template_quote_id
VITE_EMAILJS_TEMPLATE_CONTACT=your_template_contact_id
VITE_EMAILJS_TEMPLATE_FEEDBACK=your_template_feedback_id
VITE_EMAILJS_TEMPLATE_NEWSLETTER=
